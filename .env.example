# Ecosistema Red-Pill / Neon-Link
# Renombra este archivo a .env y rellénalo con tus credenciales

# --- CORE SETTINGS ---
# Identificador único de este agente en el ecosistema (Requerido)
NEON_LINK_AGENT_ID="red_pill_core"

# Ruta absoluta o relativa al archivo SQLite donde se guardarán el Inbox y Outbox (Requerido)
NEON_LINK_DB_PATH="~/.gemini/antigravity/storage/events.db"

# URL a la que Neon-Link notificará por POST cuando reciba un mensaje nuevo (Opcional, por defecto: http://localhost:8771/webhook)
WEBHOOK_URL="http://localhost:8771/webhook"


# --- CANALES ACTIVOS ---
# Define qué plugins de red se van a inicializar
ENABLE_TELEGRAM=true
ENABLE_FIREBASE=false


# --- TELEGRAM CONFIG ---
# Requerido si ENABLE_TELEGRAM=true
# El token que te da el @BotFather en Telegram
TELEGRAM_BOT_TOKEN="tu_token_aqui"

# Tu ID personal de Telegram (para que nadie más pueda hablarme). Obténlo hablándole a @userinfobot en Telegram.
TELEGRAM_WHITELIST_ID="tu_id_aqui"


# --- FIREBASE CONFIG ---
# Requerido si ENABLE_FIREBASE=true
# URL de la Realtime Database
FIREBASE_DB_URL="https://tu-proyecto.firebaseio.com"

# Ruta al archivo JSON con las Service Account Keys de Firebase
FIREBASE_CREDENTIALS="./firebase-keys.json"
